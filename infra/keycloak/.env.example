# =============================================================================
# Este ficheiro alimenta SÓ o Docker Compose do Keycloak em dev:
#   docker compose --env-file infra/keycloak/.env -f infra/keycloak/docker-compose.yaml
#
# Variáveis abaixo (KC_*, KEYCLOAK_ADMIN para bootstrap do KC) são lidas por esse compose.
# =============================================================================

KC_HTTP_PORT=8081

# Administrador da consola Keycloak (não confundir com gifto-core-admin / client secret)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak

# Test users password (documented in README)
# OBS: o import do realm (JSON) não lê env vars; este valor é apenas para padronizar documentação/scripts.
GIFTO_TEST_USERS_PASSWORD=Local123!

# =============================================================================
# As linhas seguintes NÃO são usadas pelo compose acima.
#
# São para o BACKEND Spring (criar users no KC). Em dev local, copia para o .env do core
# ou define no IDE ao correr o Spring, por exemplo:
#   KEYCLOAK_ADMIN_SERVER_URL=http://localhost:8081
# (sem /auth se o teu KC local não usa KC_HTTP_RELATIVE_PATH=/auth)
#
# Em PRODUÇÃO (Lightsail) isto vai no .env do deploy, não aqui:
#   deploy/lightsail/.env  — ver deploy/lightsail/.env.lightsail.example
# =============================================================================
# KEYCLOAK_ADMIN_SERVER_URL=http://localhost:8081
# KEYCLOAK_ADMIN_CLIENT_SECRET=core-admin-dev-secret-change-me
# KEYCLOAK_USER_INITIAL_PASSWORD=changeme
# KEYCLOAK_USER_TEMPORARY_PASSWORD=false
