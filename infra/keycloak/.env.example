# Keycloak (local dev)
KC_HTTP_PORT=8081

# Keycloak admin (local dev)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak Postgres (local dev)
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak

# Test users password (documented in README)
# OBS: o import do realm (JSON) não lê env vars; este valor é apenas para padronizar documentação/scripts.
GIFTO_TEST_USERS_PASSWORD=Local123!

# Backend Spring — Admin API (criar utilizadores ao criar tenant/merchant)
KEYCLOAK_ADMIN_SERVER_URL=http://localhost:8081
KEYCLOAK_ADMIN_CLIENT_SECRET=core-admin-dev-secret-change-me
KEYCLOAK_USER_INITIAL_PASSWORD=ChangeMeTemp!
KEYCLOAK_USER_TEMPORARY_PASSWORD=true

