# =============================================================================
# Lightsail MVP — copie para .env na mesma pasta ou use:
#   cp .env.lightsail.example .env
# Preencha todos os valores antes de subir o compose.
# =============================================================================

# IP público da instância Lightsail (sem http://). Usado por Keycloak (hostname),
# CORS do backend e documentação de URLs.
PUBLIC_IP=44.213.123.87

# Base HTTP externa (referência humana; o compose usa PUBLIC_IP nas envs do Keycloak)
EXTERNAL_BASE_URL=http://44.213.123.87

# -----------------------------------------------------------------------------
# Postgres — aplicação Spring (Flyway/JPA)
# -----------------------------------------------------------------------------
POSTGRES_DB=voucherdb
POSTGRES_USER=voucher
POSTGRES_PASSWORD=a305da3f-acd3-40fb-90b0-04524d960aa2

# -----------------------------------------------------------------------------
# Postgres — apenas Keycloak
# -----------------------------------------------------------------------------
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=2a1bf966-0fa6-4141-b741-3d440d133162

# -----------------------------------------------------------------------------
# Keycloak — administrador inicial (bootstrap)
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=8a3ff5a1-87e7-4c85-aef2-b3c03afe8232

# -----------------------------------------------------------------------------
# JWT / resource server (Spring)
# Deve ser EXATAMENTE o issuer dos tokens = URL pública + /auth/realms/gifto
# -----------------------------------------------------------------------------
KEYCLOAK_ISSUER_URI=http://44.213.123.87/auth/realms/gifto

# JWKS em rede Docker (padrão adequado para esta stack). Só altere se mudar path/realm.
# KEYCLOAK_JWK_SET_URI=http://keycloak:8080/auth/realms/gifto/protocol/openid-connect/certs

KEYCLOAK_CLIENT_ID=voucher-platform-api

# -----------------------------------------------------------------------------
# Backend — Keycloak Admin API (criar utilizadores ao criar tenant/merchant)
# O compose repassa estas variáveis ao contentor Spring (ver docker-compose.yml).
# URL = rede Docker + path /auth (igual ao KC_HTTP_RELATIVE_PATH do serviço keycloak).
# Secret = Clients → gifto-core-admin → Credentials (não é KEYCLOAK_ADMIN_PASSWORD).
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN_SERVER_URL=http://keycloak:8080/auth
KEYCLOAK_ADMIN_REALM=gifto
KEYCLOAK_ADMIN_CLIENT_SECRET=core-admin-dev-secret-change-me
# Onde estão tenant_admin / merchant_admin (resource server). Só mudar se renomeares no Keycloak.
# KEYCLOAK_ADMIN_ROLES_CLIENT_ID=voucher-platform-api
KEYCLOAK_USER_INITIAL_PASSWORD=changeme
KEYCLOAK_USER_TEMPORARY_PASSWORD=false

# -----------------------------------------------------------------------------
# Backend — segredo dos tokens de voucher (HMAC). Use string longa e aleatória.
# -----------------------------------------------------------------------------
VOUCHER_TOKEN_SECRET=7db20e71-5c35-4821-b660-95c71a44e4e2

# -----------------------------------------------------------------------------
# S3 / Lightsail Object Storage (upload de imagens na API)
# O compose repassa para o Spring: APP_STORAGE_S3_BUCKET ou, se vazio, AWS_S3_BUCKET.
# -----------------------------------------------------------------------------
APP_STORAGE_S3_BUCKET=bucket-oq7t0v
APP_STORAGE_S3_REGION=us-east-1
# APP_STORAGE_S3_PUBLIC_BASE_URL=   # opcional, se a URL pública não for a padrão AWS
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=bucket-oq7t0v